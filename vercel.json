{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "python -m pip install fastapi",
  "functions": {
    "api/index.py": {
      "excludeFiles": "{.venv/**,.agents/**,.pytest_cache/**,.streamlit/**,.vscode/**,app/**,data/**,models_store/**,tests/**,**/__pycache__/**,**/*.pyc}"
    },
    "api/main.py": {
      "excludeFiles": "{.venv/**,.agents/**,.pytest_cache/**,.streamlit/**,.vscode/**,app/**,data/**,models_store/**,tests/**,**/__pycache__/**,**/*.pyc}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
